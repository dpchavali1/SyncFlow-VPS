<?xml version="1.0" encoding="utf-8"?>
<!--
    Full Backup Rules for Android 11 and below (API 30 and below)
    Specifies what data to backup to Google Drive.
    Only included paths are backed up; everything else is excluded by default.
-->
<full-backup-content>
    <!-- Backup ONLY recovery code data (for account recovery on reinstall) -->
    <!-- User can opt-out via Settings > Backup & Restore > Google Drive Backup -->
    <include domain="sharedpref" path="syncflow_recovery.xml" />
</full-backup-content>
